# onclaw Environment Configuration Example
# Copy this file to .env and customize for your environment
#
# Environment variables loaded from .env override defaults.
# Priority: defaults < .env < ONCLAW_* env vars < CLI flags

# =============================================================================
# Core Configuration
# =============================================================================

# Log level: debug, info, warn, error (default: info)
# Set to 'debug' for detailed logging including agent messages and system prompts
ONCLAW_LOG_LEVEL=info

# Log format: text, json (default: text)
# Use 'json' for structured logging suitable for log files
ONCLAW_LOG_FORMAT=text

# Concurrency level for agent operations (default: 1)
# Higher values enable parallel tool execution but consume more RAM
# Conservative for 2GB devices: 1-2, Higher for modern systems: 4-8
ONCLAW_CONCURRENCY=1

# Maximum context tokens for LLM requests (default: 64000)
# Adjust based on model limits and available memory
# Typical ranges: 32000 (minimal) to 128000 (full context)
ONCLAW_MAX_CONTEXT_TOKENS=64000

# Default model to use (default: auto-detected by provider)
# Leave empty for provider defaults or specify a model identifier
# Examples: gpt-4o, claude-3-5-sonnet-20241022, llama3.1
ONCLAW_MODEL=

# Database path for secrets and profiles (default: ~/.onclaw/onclaw.db)
# Leave empty for default location or specify custom path
# Example: /data/onclaw/onclaw.db
ONCLAW_DB_PATH=

# Active workspace directory (default: current working directory)
# Leave empty to use current directory or specify a project path
# Example: /home/user/projects/myapp
# For paths with spaces, wrap in double quotes: ONCLAW_WORKSPACE="/home/user/my project"
ONCLAW_WORKSPACE=

# =============================================================================
# Provider Configuration (API Keys)
# =============================================================================
#
# WARNING: SECURITY FIRST
# - NEVER commit your configured .env file containing active API keys to version control.
# - Ensure .env is added to your .gitignore file.
# - Keep API keys private. Never share them in logs or public forums.
#
# Provider API keys can be set via environment variables in .env or stored securely
# in the database using: onclaw provider login <name>
# Keys defined in .env take precedence over stored database secrets.

# OpenAI API Key
#ONCLAW_PROVIDER_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Anthropic Claude API Key
#ONCLAW_PROVIDER_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Google Gemini API Key
#ONCLAW_PROVIDER_GEMINI_API_KEY=AIza-xxxxxxxxxxxxx

# AWS Bedrock Configuration (uses AWS credentials from environment or ~/.aws/)
#ONCLAW_PROVIDER_BEDROCK_API_KEY=

# Azure OpenAI API Key
#ONCLAW_PROVIDER_AZURE_OPENAI_API_KEY=xxxxxxxxxxxxx

# Ollama (keyless, runs locally)
#ONCLAW_PROVIDER_OLLAMA_API_KEY=

# Custom provider examples
#ONCLAW_PROVIDER_MYSTICAL_API_KEY=xxxxx
#ONCLAW_PROVIDER_DEEPSEEK_API_KEY=xxxxx

# =============================================================================
# Shell Tool Configuration
# =============================================================================
# Control shell command execution by the agent

# Shell execution policy: deny, allow (default: deny)
# - deny: Block all shell commands (conservative)
# - allow: Allow commands in allowlist only
#ONCLAW_TOOLS_SHELL_POLICY=deny

# Shell command allowlist (comma-separated)
# Only effective when policy=allow. Use exact command names without paths.
# Examples: ls,cat,grep,git,go,npm,docker
#ONCLAW_TOOLS_SHELL_ALLOWLIST=ls,cat,grep,git,go

# =============================================================================
# Agent Configuration
# =============================================================================

# Maximum iterations for agent loops (default: 20)
# Prevents infinite loops in multi-turn agent conversations
# Adjust based on task complexity: simple tasks=10, complex=30
#ONCLAW_AGENT_MAX_ITERATIONS=20

# =============================================================================
# Langfuse Observability (Optional)
# =============================================================================
# Enable LLM observability by providing Langfuse credentials
# Leave empty to disable observability features

# Langfuse server host (default: https://cloud.langfuse.com)
# For self-hosted: https://your-langfuse.example.com
#ONCLAW_LANGFUSE_HOST=

# Langfuse public key
#ONCLAW_LANGFUSE_PUBLIC_KEY=

# Langfuse secret key
#ONCLAW_LANGFUSE_SECRET_KEY=

# Session ID for grouping traces (optional)
# Defaults to agent name + timestamp
#ONCLAW_LANGFUSE_SESSION_ID=

# Release/version tag for deployment tracking (optional)
# Example: v1.0.0, prod-2024-06-27
#ONCLAW_LANGFUSE_RELEASE=

# Mask sensitive data in traces (default: true)
# Set to 'false' to include full prompts/responses in observability
#ONCLAW_LANGFUSE_MASK=true

# =============================================================================
# Development & Debugging
# =============================================================================

# Enable debug mode for development
# Sets log level to debug and enables verbose output
# Equivalent to: ONCLAW_LOG_LEVEL=debug
#ONCLAW_DEBUG=true

# Storage path for transcripts and conversation logs (default: ~/.config/onclaw/conversations/)
# Leave empty for default location
#ONCLAW_TRANSCRIPTS_PATH=

# =============================================================================
# Notes
# =============================================================================
#
# 1. Provider API Keys:
#    - Keys set via environment variables override stored secrets
#    - Use 'onclaw provider add' to store keys securely in the database
#    - Keyless providers (Ollama) don't require API keys
#
# 2. Debug Logging:
#    - Set ONCLAW_LOG_LEVEL=debug to see detailed agent messages
#    - Debug logs show system prompts, user inputs, and tool calls
#    - Useful for troubleshooting agent behavior
#
# 3. Resource Management:
#    - Reduce ONCLAW_MAX_CONTEXT_TOKENS on memory-constrained devices
#    - Keep ONCLAW_CONCURRENCY=1 for 2GB RAM devices
#    - Monitor memory usage with 'onclaw doctor'
#
# 4. Workspace:
#    - Relative paths are resolved from current working directory
#    - Use absolute paths for reliable workspace resolution
#    - Agent tools execute within the workspace directory
